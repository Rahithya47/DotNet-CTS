body{

font-family:Arial;
background:#eef2f7;
padding:20px;

}

h1{

text-align:center;
color:#0d6efd;

}

.container{

display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;

}

.card{

width:220px;
padding:20px;
background:white;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
text-align:center;
transition:.3s;

}

.card:hover{

transform:scale(1.05);

}

@media(max-width:768px){

.container{

flex-direction:column;

}

.card{

width:100%;

}

}
