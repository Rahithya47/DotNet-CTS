from abc import ABC, abstractmethod

class Student(ABC):

    @abstractmethod
    def details(self):
        pass

class ITStudent(Student):

    def details(self):
        print("Rahithya Kunisetty")

class IDCard:

    def display(self):
        print("Roll No: 231FA07090")

class CollegeFactory:

    def get_student(self):
        return ITStudent()

    def get_idcard(self):
        return IDCard()

factory = CollegeFactory()

factory.get_student().details()
factory.get_idcard().display()
