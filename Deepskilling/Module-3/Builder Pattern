class Student:

    def __init__(self):
        self.name = ""
        self.roll = ""
        self.department = ""

    def display(self):
        print("Name:", self.name)
        print("Roll No:", self.roll)
        print("Department:", self.department)

class StudentBuilder:

    def build(self):

        student = Student()
        student.name = "Rahithya Kunisetty"
        student.roll = "231FA07090"
        student.department = "Information Technology"

        return student

builder = StudentBuilder()

student = builder.build()
student.display()
