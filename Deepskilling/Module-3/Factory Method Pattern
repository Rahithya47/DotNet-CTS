class ITStudent:

    def details(self):
        print("Name: Rahithya Kunisetty")
        print("Department: Information Technology")

class CSEStudent:

    def details(self):
        print("Department: Computer Science")

class StudentFactory:

    def create_student(self, department):

        if department == "IT":
            return ITStudent()
        elif department == "CSE":
            return CSEStudent()

factory = StudentFactory()

student = factory.create_student("IT")
student.details()
