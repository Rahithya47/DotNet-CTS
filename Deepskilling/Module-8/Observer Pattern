class Student:

    def update(self, message):
        print("Rahithya Kunisetty:", message)


class Course:

    def __init__(self):
        self.students = []

    def subscribe(self, student):
        self.students.append(student)

    def notify(self):
        for student in self.students:
            student.update("New Python Course Available")


student = Student()

course = Course()

course.subscribe(student)

course.notify()
