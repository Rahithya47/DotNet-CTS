class UPI:

    def pay(self):
        print("Fee Paid using UPI")


class CreditCard:

    def pay(self):
        print("Fee Paid using Credit Card")


class Payment:

    def __init__(self, method):
        self.method = method

    def process(self):
        self.method.pay()


payment = Payment(UPI())
payment.process()

payment = Payment(CreditCard())
payment.process()
