class Student:

    def __init__(self, name, roll_no, department):
        self.name = name
        self.roll_no = roll_no
        self.department = department

    def display(self):
        print("Name:", self.name)
        print("Roll No:", self.roll_no)
        print("Department:", self.department)


student = Student(
    "Rahithya Kunisetty",
    "231FA07090",
    "Information Technology"
)

student.display()
